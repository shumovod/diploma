# Скопируйте в файл .env в корне репозитория и подставьте реальные значения.

OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

PERPLEXITY_API_KEY=pplx-your-key
PERPLEXITY_SONAR_MODEL=sonar
PERPLEXITY_TIMEOUT_SECONDS=120
PERPLEXITY_SEARCH_CONTEXT_SIZE=low OR medium OR high

CHROMA_PERSIST_DIRECTORY=/data/chroma
CHROMA_COLLECTION_NAME=student_helper_kb

RAG_RETRIEVE_K=4
RAG_MIN_DOCS_CHARS=80
RAG_INGEST_MAX_CHARS=360
RAG_INGEST_CHUNK_OVERLAP=40

FRONTEND_ORIGIN=http://localhost
